        }

        if (originalChasmBtn) {
          // 원래 버튼은 숨김 처리 (DOM 구조에 유지하여 Chasm Tools가 정상 인식하고 무한 재생성 오류를 막음)
          originalChasmBtn.style.setProperty('position', 'absolute', 'important');
          originalChasmBtn.style.setProperty('opacity', '0', 'important');
          originalChasmBtn.style.setProperty('width', '0', 'important');
          originalChasmBtn.style.setProperty('height', '0', 'important');
          originalChasmBtn.style.setProperty('pointer-events', 'none', 'important');
          originalChasmBtn.style.setProperty('overflow', 'hidden', 'important');
          originalChasmBtn.style.setProperty('margin', '0', 'important');
          originalChasmBtn.style.setProperty('padding', '0', 'important');
          originalChasmBtn.style.setProperty('border', 'none', 'important');
          originalChasmBtn.style.setProperty('z-index', '-9999', 'important');

          const headerContainer = document.getElementById('custom-rp-tools');
          if (headerContainer) {
            const divs = Array.from(headerContainer.children);
            // 8in1 툴바 내부의 28px 크기 빈공간(Spacer)들을 찾습니다.
            const spacers = divs.filter(el => el.tagName === 'DIV' && el.style.width === '28px' && !el.classList.contains('custom-rp-divider'));
            
            // 세 번째 빈자리(index 2)가 확보된 경우에 프록시 버튼 주입을 시작합니다.
            if (spacers.length >= 3) {
              const targetContainer = spacers[2];
              let proxyBtn = document.getElementById('chasm-heart-proxy-btn');
              
              if (!proxyBtn) {
                proxyBtn = document.createElement('button');
                proxyBtn.id = 'chasm-heart-proxy-btn';
                // 3in1/8in1의 툴바 규격을 동일하게 공유하도록 클래스를 변경하였습니다.
                proxyBtn.className = 'relative inline-flex items-center justify-center rounded-full text-sm font-medium transition-colors border border-border bg-card text-line-gray-1 hover:bg-secondary p-0 size-7';
                proxyBtn.dataset.chasmIsProxy = 'true';
                proxyBtn.innerHTML = `<span style="font-size:15px; font-weight:normal; color:#BCD0D7;">♥</span>`; // 요청하신 텍스트색(#BCD0D7) 적용
                proxyBtn.title = 'Chasm Tools (로어)';
                
                proxyBtn.onclick = (e) => {
                  e.preventDefault();
                  e.stopPropagation();
                  if (originalChasmBtn) {
                    originalChasmBtn.click();
                  }
                };
                targetContainer.appendChild(proxyBtn);
              }
            }
          }
        }
      } catch (e) {
        console.warn('[LoreInj:Heart] 버튼 변환 중 사소한 오류 발생:', e);
      }
    }

    // 로딩이나 경로 변경에 반응하도록 가볍게 실행 반복
    setInterval(applyTransformation, 500);
  }

  try {
    initHeartButtonChanger();
  } catch (e) {
    console.error('[LoreInj:Heart] 버튼 변환 기능 초기화 실패:', e);
  }
})();
