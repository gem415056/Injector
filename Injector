  function installEarlyInterceptor() {
    if (L0.__interceptorLoaded) return;
    const origFetch = _w.fetch && _w.fetch.bind(_w);
    const origWsSend = _w.WebSocket && _w.WebSocket.prototype && _w.WebSocket.prototype.send;
    
    _w.WebSocket.prototype.send = function(data) {
      const ws = this;
      if (typeof data === 'string' && data.length > 10 && data.includes('"send"')) {
          try {
              const bi = data.indexOf('[');
              const prefix = data.slice(0, bi);
              const arr = JSON.parse(data.slice(bi));
              if (arr[0] === 'send' && arr[1] && typeof arr[1].message === 'string') {
                  const orig = arr[1].message;
                  (async () => {
                      const mod = await masterInject(orig); // 마스터 함수 호출
                      arr[1].message = mod;
                      origWsSend.call(ws, prefix + JSON.stringify(arr));
                  })();
                  return;
              }
          } catch (_) {}
      }
      return origWsSend.call(this, data);
    };

    _w.fetch = async function(...args) {
      try {
          let reqUrl = (args[0] instanceof Request) ? args[0].url : String(args[0] || '');
          if (reqUrl.includes('/messages') || reqUrl.includes('/chat')) {
              let bodyText = (args[0] instanceof Request) ? await args[0].clone().text() : (args[1] && typeof args[1].body === 'string' ? args[1].body : null);
              if (bodyText) {
                  let body = JSON.parse(bodyText);
                  if (body && body.messages) {
                      const lastMsg = body.messages[body.messages.length - 1];
                      if (lastMsg && lastMsg.role === 'user') {
                          lastMsg.content = await masterInject(lastMsg.content); // 마스터 함수 호출
                          const newBody = JSON.stringify(body);
                          if (args[0] instanceof Request) args[0] = new Request(args[0], { body: newBody });
                          else { args[1] = args[1] || {}; args[1].body = newBody; }
                      }
                  }
              }
          }
      } catch (e) {}
      return origFetch.apply(this, args);
    };
    L0.__interceptorLoaded = true;
  }
  installEarlyInterceptor();

  // =====================================================================
  // 지우개 및 하트 버튼 (1.8.4 버전 보존)
