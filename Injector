  let coreInjectLogic = null; // 로어 엔진의 핵심 로직을 보관할 변수

  // 이 함수가 진짜 서버로 데이터를 쏘기 직전에 작동하는 "최종 보스"입니다.
  async function masterInject(text) {
    if (!coreInjectLogic) return text; // 엔진이 아직 안 불려왔다면 원본 그대로
    try {
      const injected = await coreInjectLogic(text);
      if (!injected || injected === text) return text;
      
      let loreBlock = injected.replace(text, '').trim();
      if (!loreBlock) return text;

      // 불렛 방지 및 마커 부착 (작성자님 1.8.4 성공 로직)
      loreBlock = loreBlock.replace(/^- /gm, '‐ '); 
      showLoreToast('✨ 로어 인젝트 완료!', true);
      return text + '\n\n⦗\n' + loreBlock + '\n⦘';
    } catch(e) {
      showLoreToast('🚨 로어 인젝트 오류!', false);
      return text;
    }
  }

  // 로어 엔진이 등록될 때마다 우리 마스터 함수에 핵심 로직만 연결해줍니다.
